# Copie este arquivo para ".env" e preencha os valores antes de rodar o projeto.
# Nenhum valor real deve ser commitado - o .env real fica de fora do git (ver .gitignore).

# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Reverse proxy / TLS (Caddy, ver docker-compose.yml e Caddyfile)
# Dominio publico que o Caddy usa pra emitir o certificado Let's Encrypt -
# precisa resolver (DNS) pro IP publico da maquina. Sem dominio proprio, use
# o IP com nip.io: 1.2.3.4 -> 1-2-3-4.nip.io
# ---------------------------------------------------------------------------
KYVO_DOMAIN=

# ---------------------------------------------------------------------------
# Banco de dados (Postgres - a camada de memoria/RAG usa full-text search nativo, sem extensoes extras)
# Em docker compose, POSTGRES_HOST deve ser o nome do servico ("postgres").
# Rodando localmente fora do compose, use "localhost".
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kyvo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kyvo

# ---------------------------------------------------------------------------
# LLM (Anthropic/DeepSeek) - o provedor/modelo/API key ativos sao configurados
# via painel /admin (guardados cifrados no Postgres), nao mais aqui. Estas
# duas vars sao a infraestrutura que protege essa config:
# ---------------------------------------------------------------------------
# Chave mestra de cifragem (AES-256-GCM) das API keys guardadas no banco.
# Gere com: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=

# Senha do painel /admin (usuario fixo "admin", HTTP Basic Auth).
ADMIN_PASSWORD=

# Opcional: seed automatico do provedor Anthropic no primeiro boot, via
# `npm run seed:llm-config` - evita ter que abrir /admin so pra rodar
# localmente. Sem efeito em runtime normal (o agente sempre le do banco).
# ANTHROPIC_API_KEY_BOOTSTRAP=

# ---------------------------------------------------------------------------
# Telegram - canal de chat do MVP
# O token do bot (@BotFather) e o secret do webhook agora sao configurados
# direto no painel /admin (guardados cifrados no Postgres), nao mais aqui.
# Estas duas vars sao so um bootstrap opcional pra dev local, equivalente ao
# ANTHROPIC_API_KEY_BOOTSTRAP acima - rode `npm run seed:telegram-config` pra
# aplicar. Sem efeito em runtime normal.
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN_BOOTSTRAP=
# TELEGRAM_WEBHOOK_SECRET_BOOTSTRAP=

# ---------------------------------------------------------------------------
# Anexos de mensagem (imagem/audio/documento) e transcricao de audio
# ---------------------------------------------------------------------------
# Pasta local onde os arquivos enviados (Telegram ou admin) sao salvos.
UPLOADS_DIR=./uploads
# Tamanho maximo de anexo aceito, em bytes (default: 15MB).
MAX_ANEXO_BYTES=15728640

# Transcricao de mensagens de voz via Groq (Whisper) - a API key agora e
# configurada direto no painel /admin (guardada cifrada no Postgres), nao
# mais aqui. Sem essa chave, o audio ainda e salvo como anexo, mas o agente
# nao recebe o conteudo falado. https://console.groq.com/keys
#
# Bootstrap opcional pra dev local, equivalente ao ANTHROPIC_API_KEY_BOOTSTRAP
# acima - rode `npm run seed:groq-config` pra aplicar. Sem efeito em runtime
# normal.
# GROQ_API_KEY_BOOTSTRAP=

# ---------------------------------------------------------------------------
# Open Finance (Pluggy) - integracao bancaria, a partir da Fase 2
# https://dashboard.pluggy.ai/
# ---------------------------------------------------------------------------
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
