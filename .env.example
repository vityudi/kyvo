# Copie este arquivo para ".env" e preencha os valores antes de rodar o projeto.
# Nenhum valor real deve ser commitado - o .env real fica de fora do git (ver .gitignore).

# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Banco de dados (Postgres com extensao pgvector)
# Em docker compose, POSTGRES_HOST deve ser o nome do servico ("postgres").
# Rodando localmente fora do compose, use "localhost".
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kyvo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kyvo

# ---------------------------------------------------------------------------
# Claude (Anthropic) - motor de IA principal
# https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# Telegram - canal de chat do MVP
# Crie um bot com @BotFather e cole o token aqui.
# TELEGRAM_WEBHOOK_SECRET e opcional, mas recomendado: o Telegram reenvia esse
# valor no header "X-Telegram-Bot-Api-Secret-Token" a cada requisicao, o que
# permite validar que o webhook realmente veio do Telegram.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Embeddings (Voyage AI) - usado pela camada de memoria/RAG
# Pendencia documentada: confirmar modelo e dimensao do vetor antes de usar em
# producao (ver docs de arquitetura de memoria).
# ---------------------------------------------------------------------------
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ---------------------------------------------------------------------------
# Open Finance (Pluggy) - integracao bancaria, a partir da Fase 2
# https://dashboard.pluggy.ai/
# ---------------------------------------------------------------------------
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
